# Smart Money Follows — Environment Configuration
# Copy to config/.env and fill in your API keys
# Signal sources (SEC EDGAR + House/Senate Stock Watcher) are free, no keys needed

# Tiingo — fundamentals & price data
TIINGO_API_KEY=

# FRED — macro indicators (free at https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# Database (SQLite default, swap to PostgreSQL URI for production)
DATABASE_URL=sqlite:///./smart_money.db

# Pipeline
CONVICTION_THRESHOLD=0.6
PIPELINE_MODE=oneshot
SCHEDULE_INTERVAL_MINUTES=60
LOG_LEVEL=INFO

# Slack Bot (Socket Mode) — create app at https://api.slack.com/apps
# Bot Token Scopes: chat:write, app_mentions:read, channels:history
# Enable Socket Mode to get the App-Level Token
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token
SLACK_WEBHOOK_URL=
